<!doctype html>
<html>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
<div class="main w-full min-h-screen bg-zinc-950 text-white">

    <!-- FORM SECTION -->
    <div class="form flex items-center justify-center py-20 px-4">
        <form action="/create" method="POST"
              class="w-full max-w-lg bg-zinc-900 p-8 rounded-3xl 
                     border border-zinc-800 shadow-xl">

            <h2 class="text-2xl font-semibold mb-6 text-center tracking-wide">
                Create New Task
            </h2>

            <input 
                type="text" 
                name="title"
                placeholder="Title goes here"
                class="w-full p-4 rounded-xl bg-zinc-800 
                       border border-zinc-700 
                       focus:border-blue-500 
                       focus:ring-2 focus:ring-blue-500/40
                       outline-none transition-all duration-300"
            />

            <textarea 
                name="detail"
                placeholder="Write your task in detail..."
                class="w-full p-4 rounded-xl bg-zinc-800 
                       border border-zinc-700 
                       focus:border-blue-500 
                       focus:ring-2 focus:ring-blue-500/40
                       outline-none transition-all duration-300 
                       resize-none h-32 mt-4"
            ></textarea>

            <input 
                type="submit" 
                value="Add Task"
                class="w-full p-4 mt-6 rounded-xl 
                       bg-blue-600 hover:bg-blue-500
                       active:scale-95
                       font-semibold tracking-wide
                       transition-all duration-300 
                       shadow-lg shadow-blue-600/30 cursor-pointer"
            />
        </form>
    </div>

    <!-- TASK SECTION -->
    <div class="task px-6 pb-20">

        <div class="task-container max-w-5xl mx-auto grid md:grid-cols-2 gap-6">

            <% if (files && files.length > 0) { %>

                <% files.forEach((file) => { %>

                    <div class="bg-zinc-900 p-6 rounded-2xl 
                                border border-zinc-800 
                                hover:border-blue-500/40
                                transition-all duration-300
                                hover:-translate-y-1">

                        <h1 class="text-lg font-semibold mb-3">
                            <%= file.title %>
                        </h1>

                        <p class="text-zinc-400 mb-4">
                            <%= file.detail %>
                        </p>

                        <a href="/task/<%= file.id %>" 
                           class="text-blue-400 hover:text-blue-300 transition-colors duration-300">
                            Read more →
                        </a>
                    </div>

                <% }) %>

            <% } else { %>

                <h3 class="col-span-2 text-center text-zinc-400 text-xl mt-12">
                    No task found
                </h3>

            <% } %>

        </div>

    </div>

</div>
</body>
</html>